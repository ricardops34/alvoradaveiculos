# Stack do Portainer / producao
HOST_URL=alvorada.seudominio.com.br
IMAGE_TAG=latest

# PostgreSQL acessivel pela rede externa network_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=alvorada_db
DB_USER=alvorada
DB_PASS=troque-por-uma-senha-segura

# Segredo usado para assinar os tokens JWT de autenticacao. Obrigatorio em producao
# (o servidor recusa iniciar sem isso). Gere um valor aleatorio forte, ex: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-aleatorio-forte
